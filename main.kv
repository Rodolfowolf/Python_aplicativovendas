#:include kv/homepage.kv
#:include kv/ajustespage.kv

FloatLayout:
    canvas:
        Color:
            rgb: (0.5, 0.5, 1, 1)
        Rectangle:
            size: self.size
            pos: self.pos
    Image:
        pos_hint:{"right":1, "top":0.9}
        size_hint:1, 0.2
        source: "icones/hash.png"
    ScreenManager:
        pos_hint:{"right":1, "top": 0.7}
        size_hint:1, 0.7
        id: screen_manager
        HomePage:
            name: "homepage"
            id: homepage
        AjustesPage:
            name: "ajustespage"
            id: ajustespage

