<AjustesPage>:
    FloatLayout:
        canvas:
            Rectangle:
                size: self.size
                pos: self.pos
                source: "icones/bg1.png"
        Label:
            canvas.before:
                Rectangle:
                    pos:self.pos
                    size: self.size
                    source: "icones/botao_fino.png"
            pos_hint: {"right":1, "top":1}
            size_hint:0.7, 0.2
            bold: True
            text: "Seu ID unico"
            id: id_vendedor

        #Mudar foto de perfil
        ImageButton:
            pos_hint: {"right":0.5, "top":0.7}
            size_hint: 0.5, 0.15
            source: "icones/foto_perfil.png"
        LabelButton:
            pos_hint: {"right":0.9, "top":0.7}
            size_hint: 0.5, 0.15
            text: "Mudar Foto de perfil"
            on_release: print("Ir para tela mudar foto perfil")


        #Adicionar vendedor
        ImageButton:
            pos_hint: {"right":0.5, "top":0.5}
            size_hint: 0.5, 0.15
            source: "icones/adicionar_vendedor.png"
            on_release: print("Ir para tela acompanhar vendedor")
        LabelButton:
            pos_hint: {"right":0.9, "top":0.5}
            size_hint: 0.5, 0.15
            text: "Acompanhar vendedor"
            on_release: print("Ir para tela acompanhar vendedor")


        #Ver todas as vendas
        ImageButton:
            pos_hint: {"right":0.5, "top":0.3}
            size_hint: 0.5, 0.15
            source: "icones/vendas_empresa.png"
            on_release: print("Ir para tela ver todas as vendas")
        LabelButton:
            pos_hint: {"right":0.9, "top":0.3}
            size_hint: 0.5, 0.15
            text: "Ver todas as vendas"
            on_release: print("Ir para tela ver todas as vendas")


        #Botao voltar
        FloatLayout:
            pos_hint: {"right": 1, "top":0.12}
            size_hint: 1, 0.12
            canvas:
                Color:
                    rgb: (0.35, 0.35, 1.42, 1)
                Rectangle:
                    size: self.size
                    pos: self.pos
            ImageButton:
                pos_hint: {"right":0.2,"top":0.9}
                size_hint: 0.2, 0.8
                source: "icones/voltar.png"
                on_release: app.mudar_tela("homepage")