<AjustesPage>:
    FloatLayout:
        Label:
            pos_hint: {"right":1, "top":1}
            size_hint:1, 0.85
            text: "Pagina de ajustes"
        Button:
            pos_hint: {"right": 0.33, "top":0.15}
            size_hint: 0.33, 0.15
            text: "Voltar Home page"
            on_release: app.mudar_tela("homepage")